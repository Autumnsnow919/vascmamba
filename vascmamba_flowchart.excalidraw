    {
      "type": "text", "id": "txtH", "x": 140, "y": 964, "width": 860, "height": 64, "angle": 0,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2,
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null,
      "seed": 24, "version": 1, "versionNonce": 24, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false,
      "text": "⑧ 池化 + 分类头\nmean over sequence dim：(B,8,32) → (B,32)\nhead = LayerNorm → Linear(32→32)+GELU+Dropout(0.3) → Linear(32→2) → logits (B, 2)",
      "fontSize": 15, "fontFamily": 5, "textAlign": "left", "verticalAlign": "top", "baseline": 57,
